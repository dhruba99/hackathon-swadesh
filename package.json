{
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n client,server \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "next dev",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "next build",
    "start:client": "next start",
    "start:server": "node --import tsx server/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@hono/node-server": "^1.19.12",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "next": "^15.5.6",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
